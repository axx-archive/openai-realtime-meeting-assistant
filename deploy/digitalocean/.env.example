# Copy this to .env on the Droplet and fill in real values.
OPENAI_API_KEY=sk-proj-your-key
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_REASONING_EFFORT=low
OPENAI_REALTIME_VAD_TYPE=semantic_vad
OPENAI_REALTIME_VAD_EAGERNESS=high
MEETING_TRANSCRIPT_LANE_ENABLED=true
# Transcript-lane model: leave unset — the code default is gpt-4o-transcribe,
# which accepts the domain-vocabulary prompt + near-field noise reduction the
# lane sends (transcription_lane.go), so proper nouns like StationTenn survive.
# WARNING: whisper-family ids (e.g. gpt-realtime-whisper) silently DISABLE
# vocabulary biasing (the prompt param is unsupported there), and before the
# model gate a whisper pin broke live sessions outright (2026-07-08 incident).
# Uncomment only to deliberately override the default:
# OPENAI_TRANSCRIPT_MODEL=gpt-4o-transcribe
MEETING_ROOM_PASSWORD=change-me
MEETING_ROOM_MAX_PARTICIPANTS=10
MEETING_MEMORY_PATH=/app/data/meeting-memory.jsonl
# --- W1 canonical shadow substrate -----------------------------------------
# Generate once with: openssl rand -hex 32
# Keep this password and the URL password identical. PostgreSQL is private to
# the Compose network; no database port is published by docker-compose.yml.
BONFIRE_CANONICAL_POSTGRES_PASSWORD=replace-with-openssl-rand-hex-32
BONFIRE_CANONICAL_DATABASE_URL=postgres://bonfire:replace-with-openssl-rand-hex-32@canonical-postgres:5432/bonfire?sslmode=disable
BONFIRE_CANONICAL_TENANT_ID=bonfire
# W1 deploys shadow: JSON/JSONL remains authoritative while parity is proven.
# `required` is a later cutover gate and refuses startup or covered writes when
# the canonical chain is unhealthy.
BONFIRE_CANONICAL_MODE=shadow

# --- W4 isolated restore gate (leave OFF in the normal live deployment) ------
# A restored environment sets this block only after `bonfire-dr secure-preflight`
# emits a fresh ready:true receipt. Public verification keys are safe to install;
# private authority/manifest/provider/custody/encryption/release keys never belong
# on an app or restore host. Every receipt is environment + nonce + candidate +
# image + authority-head bound and is atomically consumed before stores open.
# BONFIRE_RESTORE_MODE=isolated
# BONFIRE_RESTORE_RECEIPT_PATH=/run/bonfire-dr/drill-receipt.json
# BONFIRE_RESTORE_MANIFEST_PATH=/run/bonfire-dr/manifest.json
# BONFIRE_RESTORE_ENVELOPE_PATH=/run/bonfire-dr/restored-envelope.enc
# BONFIRE_RESTORE_ENVIRONMENT_ID=restore-host-unique-id
# BONFIRE_RESTORE_NONCE=at-least-32-random-bytes
# BONFIRE_RUNNING_IMAGE_DIGEST_PIN_PATH=/run/bonfire-dr/running-image.sha256
# BONFIRE_DR_AUTHORITY_HEAD_PIN_PATH=/run/bonfire-dr/current-authority-head.sha256
# BONFIRE_DR_PROTECTED_ROOTS_PATH=/run/bonfire-dr/protected-roots.json
# BONFIRE_DR_RESTORE_RECEIPT_PUBLIC_KEY_ID=restore-receipt-key-v1
# BONFIRE_DR_RESTORE_RECEIPT_PUBLIC_KEY=<ed25519-public-key-base64-or-hex>
# BONFIRE_DR_AUTHORITY_PUBLIC_KEY_ID=authority-key-v1
# BONFIRE_DR_AUTHORITY_PUBLIC_KEY=<ed25519-public-key-base64-or-hex>
# BONFIRE_DR_MANIFEST_PUBLIC_KEY_ID=manifest-key-v1
# BONFIRE_DR_MANIFEST_PUBLIC_KEY=<ed25519-public-key-base64-or-hex>
# BONFIRE_DR_OFFSITE_PROVIDER_PUBLIC_KEY_ID=provider-key-v1
# BONFIRE_DR_OFFSITE_PROVIDER_PUBLIC_KEY=<ed25519-public-key-base64-or-hex>
# BONFIRE_DR_CUSTODY_PUBLIC_KEY_ID=custody-key-v1
# BONFIRE_DR_CUSTODY_PUBLIC_KEY=<ed25519-public-key-base64-or-hex>
# BONFIRE_DR_ENCRYPTION_PUBLIC_KEY_ID=encryption-key-v1
# BONFIRE_DR_ENCRYPTION_PUBLIC_KEY=<ed25519-public-key-base64-or-hex>
# BONFIRE_DR_RELEASE_PUBLIC_KEY_ID=release-key-v1
# BONFIRE_DR_RELEASE_PUBLIC_KEY=<ed25519-public-key-base64-or-hex>
# BONFIRE_RESTORE_RECEIPT_CONSUMED_PATH=/var/lib/bonfire-restore-gate/consumed
MEETING_BRAIN_INTERVAL=5m
OPENAI_BRAIN_MODEL=gpt-5.5
MEETING_BRAIN_BACKFILL=false
MEETING_TIME_ZONE=America/Los_Angeles

# --- Semantic recall lane (in-process embeddings; study §6 item 2.4) ---------
# An ambient maintainer embeds the CONSOLIDATED knowledge corpus (brains,
# digests, narratives, decisions, reflections, run logs, notes, and artifact
# title+excerpt — never the transcript firehose, never chat threads) into a
# sidecar next to the store and an in-RAM matrix; the recall lane fuses those
# cosine neighbours with the lexical search results (weighted RRF). It uses the
# OpenAI embeddings API and the SAME OPENAI_API_KEY as the rest of the OS.
# KEYLESS POSTURE: with no OPENAI_API_KEY the maintainer never starts and recall
# silently degrades to lexical-only (one boot log line) — no new hard dependency.
# EMBEDDINGS_DISABLED=false          # truthy turns the whole lane off
# EMBEDDINGS_MODEL=text-embedding-3-small   # 1536-dim; the study's pick
# EMBEDDINGS_INTERVAL=3m             # maintainer sweep cadence; 0/off disables
# EMBEDDINGS_MAX_BATCH=128           # NEW/CHANGED entries embedded per pass
#                                    # (lazy backfill across passes, newest first)
# EMBEDDINGS_LANE_TOPK=12            # cosine neighbours pulled per query
# EMBEDDINGS_LEXICAL_WEIGHT=1.0      # RRF weight of the lexical channel
# EMBEDDINGS_SEMANTIC_WEIGHT=0.85    # RRF weight of the semantic channel
# EMBEDDINGS_PATH=/app/data/embeddings.jsonl   # sidecar; defaults beside the
#                                    # store (rides the data-dir backup snapshot)
# Session-end rule: a room session ends after the room has been empty this
# long; the prior meeting is silently auto-archived and the next join starts
# a fresh context. Defaults to 30m — only set to override.
# MEETING_IDLE_END_GRACE=30m

# Use the Droplet public IPv4 address here so WebRTC candidates are reachable
# from browsers outside the Docker network.
PION_NAT1TO1_IP=203.0.113.10
PION_UDP_PORT_RANGE=40000-40100

# Per-outbound-video-stream depth of the SFU's RTP retransmission buffer: how
# many recent packets the NACK responder keeps so a subscriber can recover a
# loss via RTX instead of waiting for a keyframe. Default 1024. Must be a power
# of two in [1, 32768]; any unset, non-numeric, out-of-range, or non-power-of-two
# value logs an error and falls back to 1024, so a bad config can never enlarge
# the buffer without bound or fail peer-connection setup. Budget ~1.5 KB per
# retained packet (a full-MTU video packet) — ~1.5 MiB per active outbound video
# stream at the default 1024.
# ROOM_NACK_BUFFER_PACKETS=1024

# Optional but recommended for locked-down guest/office networks where direct
# UDP to the Droplet is blocked.
# MEETING_STUN_URLS=stun:stun.l.google.com:19302
# MEETING_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# MEETING_TURN_USERNAME=meetingassist
# MEETING_TURN_CREDENTIAL=replace-with-turn-secret

# Point a real DNS record here, or use a nip.io hostname for a quick demo:
# 203.0.113.10.nip.io
MEETING_HOST=203.0.113.10.nip.io
MEETING_ALLOWED_ORIGINS=https://203.0.113.10.nip.io

# Optional sidecar Codex runner for Realtime 2 controlled work threads.
# Start with: docker compose --profile codex up -d --build
# Keep Codex auth inside the codex_home Docker volume.
# BONFIRE_AGENT_THREAD_WORKER=codex_exec
# BONFIRE_CODEX_RUNNER_MODE=sidecar_queue
# BONFIRE_CODEX_WORKSPACE_HOST_PATH=/opt/meetingassist-workspace
# BONFIRE_CODEX_CWD=/workspace/meetingassist
# BONFIRE_CODEX_QUEUE_PATH=/app/data/codex-runner-jobs
# BONFIRE_RUNNER_TOKEN=replace-with-openssl-rand-hex-32
# BONFIRE_CODEX_SANDBOX=workspace-write
# BONFIRE_CODEX_APPROVAL_POLICY=never
# BONFIRE_CODEX_REASONING_EFFORT=high
# BONFIRE_CODEX_TIMEOUT=20m

# --- Workflow ticker (card 067) ----------------------------------------------
# ~5-minute status re-scan that relaunches human-APPROVED but stuck proposals
# and any auto_run-lane work carrying a recorded standing approval. Model-free;
# it only ever launches one agent thread per proposal (never /goal or packaging),
# capped per pass. Defaults are safe — leave commented to accept them.
# BONFIRE_WORKFLOW_TICKER_INTERVAL=5m       # duration; 0/off/false/disabled turns it off
# BONFIRE_WORKFLOW_TICKER_DISABLED=false    # truthy disables the ticker
# BONFIRE_WORKFLOW_TICKER_MAX_PER_PASS=2    # max launches per tick

# --- Web Push / installable PWA (card 089) -----------------------------------
# Phone push for durable notifications (chat mentions, task proposals, agent
# milestones). NO env var is strictly required: on first boot the server mints a
# VAPID keypair and persists it to /app/data/vapid-keys.json (kept across
# deploys like users.json). Set the two keys below only to pin a keypair you
# generated yourself (e.g. to keep subscriptions valid across a data wipe).
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# Subscriber contact sent in the VAPID JWT (push services require a mailto:).
# WEB_PUSH_SUBSCRIBER=mailto:noreply@thebonfire.xyz
# Device subscriptions persist to /app/data/push-subscriptions.json by default;
# override the path only for test isolation.
# PUSH_SUBSCRIPTIONS_PATH=/app/data/push-subscriptions.json
# NOTE: the container needs outbound HTTPS to the push services
# (fcm.googleapis.com, web.push.apple.com, push.mozilla.org) — ca-certificates
# is already in the runtime image, so no extra setup on a standard Droplet.

# --- Anthropic Fable orchestrator (OPS-3 activation) -------------------------
# The moment ANTHROPIC_API_KEY is set, agent-runner selection defaults to
# anthropic_fable (see selectedAgentRunnerName in agent_runner_iface.go), so
# /goal, grill reports, and packaging deliverables run on Fable instead of the
# Codex fallback. Uncomment the three lines below together: pin the runner
# explicitly (never rely on inference) and pin the sidecar model — an unset
# BONFIRE_CODEX_MODEL means "whatever the Codex CLI defaults to on the host".
# NOTE: the Anthropic org that owns this key must be on 30-day data retention;
# claude-fable-5 returns 400 on every request under zero-data-retention orgs.
# ANTHROPIC_API_KEY=sk-ant-your-key
# BONFIRE_AGENT_RUNNER=anthropic_fable
# BONFIRE_CODEX_MODEL=gpt-5.5

# Orchestrator/deliverable dials, read in agent_runner_anthropic.go. The names
# below must match that file exactly (BONFIRE_ORCHESTRATOR_* for the control
# loop, BONFIRE_DELIVERABLE_* for the contract-bearing /goal deliverable
# subtask) — if a dial is renamed or added there, update this block in the same
# change; the code defaults there are authoritative when a line stays unset.
# Spec target (packaging-os-analysis-2026-07-05): Fable 5 at effort HIGH for
# orchestration + deliverables. Values below mirror that target.
# BONFIRE_ORCHESTRATOR_MODEL=claude-fable-5
# BONFIRE_ORCHESTRATOR_EFFORT=high
# BONFIRE_ORCHESTRATOR_MAX_TURNS=24
# BONFIRE_ORCHESTRATOR_MAX_TOKENS=4096
# BONFIRE_ORCHESTRATOR_TIMEOUT=15m
# BONFIRE_DELIVERABLE_EFFORT=high
# BONFIRE_DELIVERABLE_MAX_TOKENS=32768

# --- Calendar (card 084) -----------------------------------------------------
# The .ics slice needs NO configuration: GET /calendar/event.ics turns a card
# key date into a downloadable all-day event, and the per-milestone "add to
# calendar" button in the key-dates timeline works out of the box. The three
# vars below only RESERVE the future Google Calendar sync seam — set all three
# together and /client-config flips calendar.google to true so the frontend can
# light up a Google button once that wave lands. Half-set = still off.
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URL=https://$MEETING_HOST/calendar/google/callback

# --- Data backups (memory-architecture study §6 Phase 0.1) -------------------
# The whole company brain lives in the data/ volume on this one droplet. Without
# a backup, one disk failure or fat-finger is total, permanent loss. On boot the
# server starts a nightly in-process snapshot worker: it tar.gz's the data dir,
# optionally AES-256-GCM encrypts it, keeps a rotating LOCAL ring inside the
# volume, and — when the BACKUP_S3_* block below is set — PUTs the encrypted
# snapshot OFFSITE. No env is required to get a local ring; leave the S3 block
# unset and offsite stays dormant (see the boot log line). See README.md
# ("Data backups") for the restore procedure. First snapshot runs ~3 min after
# boot so a fresh deploy proves the path.
#
# Interval / retention (safe defaults; leave unset to accept them):
# BACKUP_INTERVAL_HOURS=24     # 24h default; 0/off/false/disabled turns it off
# BACKUP_RING_KEEP=7           # newest N local snapshots kept, older deleted
# BACKUP_DISABLED=false        # truthy disables the worker entirely
# BACKUP_INCLUDE_BLOBS=true    # blobs/ (content-addressed uploads = every
#                              # uploaded file body) are INCLUDED by default so a
#                              # restore is complete. Set falsy (0/off/false/no)
#                              # to exclude them for a smaller snapshot + less RAM
#                              # during encrypt — a restore then loses file bodies.
#
# Encryption. Set a key to encrypt every snapshot (local ring AND offsite). The
# value may be 32 raw bytes as hex (64 chars) or base64, or any passphrase
# (SHA-256'd to a 32-byte key). WITHOUT a key: local snapshots are written
# UNENCRYPTED and OFFSITE UPLOAD IS REFUSED (fail-closed — the brain is never
# shipped off the box in the clear). Generate one with: openssl rand -hex 32
# BACKUP_ENCRYPTION_KEY=
#
# Offsite target (S3-compatible; DigitalOcean Spaces shown). All four of
# ENDPOINT/BUCKET/ACCESS_KEY/SECRET_KEY must be set or offsite stays dormant.
# ENDPOINT is the Spaces region host WITHOUT the bucket and WITHOUT a scheme.
# REGION must be the Spaces region slug (nyc3, sfo3, ...); it defaults to
# us-east-1. Uploads use pure-stdlib AWS SigV4 — no extra tooling on the box.
# BACKUP_S3_ENDPOINT=nyc3.digitaloceanspaces.com
# BACKUP_S3_REGION=nyc3
# BACKUP_S3_BUCKET=bonfire-backups
# BACKUP_S3_ACCESS_KEY=DO00XXXXXXXXXXXXXXXX
# BACKUP_S3_SECRET_KEY=replace-with-spaces-secret
# BACKUP_S3_PREFIX=bonfire/     # optional object-key prefix inside the bucket
# BACKUP_S3_PATH_STYLE=false    # false => https://bucket.endpoint/key (Spaces
#                               # default); true => https://endpoint/bucket/key
